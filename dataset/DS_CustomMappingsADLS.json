{
	"name": "DS_CustomMappingsADLS",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"ParamFolderFileName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@split(dataset().ParamFolderFileName,'|')[1]",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@split(dataset().ParamFolderFileName,'|')[0]",
					"type": "Expression"
				},
				"fileSystem": "mycontainer"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": false,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "Name",
				"type": "String"
			},
			{
				"name": "Category",
				"type": "String"
			},
			{
				"name": "Status",
				"type": "String"
			},
			{
				"name": "Error",
				"type": "String"
			}
		]
	}
}